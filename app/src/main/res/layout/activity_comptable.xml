<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textTitreComptable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/espace_comptable"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textSousTitreComptable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="@string/fiches_transmises_a_traiter" />

    <Button
        android:id="@+id/btnDeconnexionComptable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/deconnexion" />

    <TextView
        android:id="@+id/textAucuneFicheComptable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/aucune_fiche_comptable"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerComptable"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />

</LinearLayout>
